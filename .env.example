# ============================================================
#  JARVIS v2.0 — Environment Variables Template
# ============================================================

# ── Groq AI (RECOMMENDED - Free tier tersedia)
# Dapatkan API key di: https://console.groq.com/keys
GROQ_ENABLED=true
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MAX_OUTPUT_TOKENS=120
GROQ_TEMPERATURE=0.4

# ── Gemini AI (Alternative / Fallback)
# Dapatkan API key di: https://aistudio.google.com/app/apikey
GEMINI_ENABLED=false
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=120
GEMINI_TEMPERATURE=0.4
GEMINI_TOP_P=0.95
